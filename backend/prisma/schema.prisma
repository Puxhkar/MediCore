datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         Role
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  doctor       Doctor?
  auditLogs    AuditLog[]
}

enum Role {
  ADMIN
  RECEPTIONIST
  DOCTOR
}

model Hospital {
  id            String    @id @default(uuid())
  name          String
  address       String
  city          String    @default("Pune")
  lat           Float
  lng           Float
  contactNumber String?   @map("contact_number")
  isAvailable   Boolean   @default(true) @map("is_available")
  doctors       Doctor[]
  beds          Bed[]
  invitations   DoctorInvitation[]
}

model Doctor {
  id              String    @id @default(uuid())
  user            User      @relation(fields: [userId], references: [id])
  userId          String    @unique @map("user__id")
  hospital        Hospital? @relation(fields: [hospitalId], references: [id])
  hospitalId      String?   @map("hospital_id")
  speciality      String    // Matches user snippet
  department      String
  licenseNumber   String    @unique @map("license_number")
  shiftStart      String    @map("shift_start")
  shiftEnd        String    @map("shift_end")
  consultationFee Float     @map("consultation_fee") 
  fees            Int?      
  experience      Int?      
  qualification   String?   
  isAvailable     Boolean   @default(true) @map("is_available")
  patients        Patient[]
  appointments    Appointment[]
  locations       DoctorLocation[]
  invitations     DoctorInvitation[]
  reviews         Review[]
}

model Bed {
  id                 String   @id @default(uuid())
  hospital           Hospital @relation(fields: [hospitalId], references: [id])
  hospitalId         String   @map("hospital_id")
  bedNumber          String   @unique @map("bed_number")
  type               BedType
  ward               String
  floor              String
  isOccupied         Boolean  @default(false) @map("is_occupied")
  isUnderMaintenance Boolean  @default(false) @map("is_under_maintenance")
  patients           Patient[]
}

enum BedType {
  ICU
  GENERAL
}

model Patient {
  id             String        @id @default(uuid())
  name           String
  age            Int
  gender         Gender
  phone          String?
  email          String?
  bloodType      String?       @map("blood_type")
  severity       Int           // 1-10
  status         PatientStatus
  bed            Bed?          @relation(fields: [bedId], references: [id])
  bedId          String?       @map("bed_id")
  doctor         Doctor?       @relation(fields: [doctorId], references: [id])
  doctorId       String?       @map("doctor_id")
  registeredAt   DateTime      @default(now()) @map("registered_at")
  admittedAt     DateTime?     @map("admitted_at")
  dischargedAt   DateTime?     @map("discharged_at")
  appointments   Appointment[]
  emergencyQueue EmergencyQueue[]
  bills          Bill[]
  reviews        Review[]
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PatientStatus {
  REGISTERED
  WAITING
  ADMITTED
  UNDER_TREATMENT
  DISCHARGED
}

model Appointment {
  id              String            @id @default(uuid())
  patient         Patient           @relation(fields: [patientId], references: [id])
  patientId       String            @map("patient__id")
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  doctorId        String            @map("doctor__id")
  serviceType     String?           @map("service_type")
  approvalStatus  ApprovalStatus    @default(PENDING) @map("approval_status")
  scheduledAt     DateTime          @map("scheduled_at")
  endsAt          DateTime          @map("ends_at")
  durationMinutes Int               @map("duration_minutes")
  reason          String
  status          AppointmentStatus @map("status")
  notes           String?
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model EmergencyQueue {
  id          String         @id @default(uuid())
  patient     Patient        @relation(fields: [patientId], references: [id])
  patientId   String         @map("patient_id")
  severity    Int
  reason      String
  symptoms    String?
  status      QueueStatus
  queuedAt    DateTime       @default(now()) @map("queued_at")
  processedAt DateTime?      @map("processed_at")
}

enum QueueStatus {
  QUEUED
  PROCESSED
  CANCELLED
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  user        User     @relation(fields: [performedBy], references: [id])
  performedBy String   @map("performed_by")
  oldValue    String?  @map("old_value") 
  newValue    String?  @map("new_value") 
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")
}

model Bill {
  id          String     @id @default(uuid())
  patient     Patient    @relation(fields: [patientId], references: [id])
  patientId   String     @map("patient_id")
  totalAmount Float      @map("total_amount")
  status      BillStatus
  generatedAt DateTime   @default(now()) @map("generated_at")
  paidAt      DateTime?  @map("paid_at")
}

enum BillStatus {
  PENDING
  PAID
}

model DoctorLocation {
  id            String   @id @default(uuid())
  doctor        Doctor   @relation(fields: [doctorId], references: [id])
  doctorId      String   @map("doctor_id")
  name          String
  address       String
  city          String
  phone         String?
  isActive      Boolean  @default(true) @map("is_active")
  totalPatients Int      @default(0) @map("total_patients")
}

model Review {
  id        String   @id @default(uuid())
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  doctorId  String   @map("doctor_id")
  patient   Patient  @relation(fields: [patientId], references: [id])
  patientId String   @map("patient_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
}

model DoctorInvitation {
  id         String           @id @default(uuid())
  doctor     Doctor           @relation(fields: [doctorId], references: [id])
  doctorId   String           @map("doctor_id")
  hospital   Hospital         @relation(fields: [hospitalId], references: [id])
  hospitalId String           @map("hospital_id")
  status     InvitationStatus @default(PENDING)
  createdAt  DateTime         @default(now()) @map("created_at")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
}
